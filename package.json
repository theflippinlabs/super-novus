{
  "name": "super-novus",
  "version": "2.0.0",
  "description": "SUPER NOVUS — a Novarys cosmic arcade experience",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "sirv dist --host 0.0.0.0 --port ${PORT:-8080} --single --etag"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "@walletconnect/ethereum-provider": "^2.11.0",
    "sirv-cli": "^3.0.1",
    "three": "0.128.0",
    "viem": "^2.55.4"
  },
  "devDependencies": {
    "@types/three": "0.128.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.10"
  }
}
